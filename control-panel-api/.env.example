DOCKER_HOST=unix:///var/run/docker.sock
TARGET_IMAGE=sandbox-target-app

# Database backend: sqlite (default) or db2
DB_PROVIDER=sqlite

# Db2 connection (required when DB_PROVIDER=db2)
# Option 1: Full DSN
DB2_DSN=
# Example: DATABASE=<db>;HOSTNAME=<host>;PORT=50000;PROTOCOL=TCPIP;UID=<user>;PWD=<pass>;Security=SSL;

# Option 2: Individual fields (used when DB2_DSN is not set)
DB2_HOST=
DB2_PORT=50000
DB2_DATABASE=
DB2_USERNAME=
DB2_PASSWORD=
DB2_SECURITY=SSL

# Optional SSL CA certificate configuration
# DB2_SSL_CA_FILE=/absolute/path/to/ca-cert.pem
DB2_SSL_CA_NAME=db2-ca.pem
DB2_SSL_CA_BASE64=

# Claude API key
CLAUDE_API_KEY=YOUR_CLAUDE_API_KEY
