DB_PROVIDER=file

# Optional Db2 compatibility fields (not required in current file-store mode)
DB2_DSN=
DB2_HOST=
DB2_PORT=50000
DB2_DATABASE=
DB2_USERNAME=
DB2_PASSWORD=
DB2_SECURITY=SSL

# Auth credentials for role-based login (set real values before sharing/deploying)
AUTH_ADMIN_EMAIL=admin@example.com
AUTH_ADMIN_PASSWORD=change-me-admin-password
AUTH_USER_EMAIL=user@example.com
AUTH_USER_PASSWORD=change-me-user-password